# --- LLM ---
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional, helps OpenRouter analytics — set to your repo URL if you want
OPENROUTER_HTTP_REFERER=https://github.com/yourname/rag-api
OPENROUTER_X_TITLE=RAG API homework

# --- Postgres (local Docker by default; switch to Supabase for prod) ---
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag

# --- Redis (local Docker by default; switch to Upstash for prod) ---
REDIS_URL=redis://localhost:6379/0

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- RAG ---
RAG_TOP_K=3
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=50

# --- Cache ---
CACHE_SIMILARITY_THRESHOLD=0.80
CACHE_TTL_SECONDS=3600

# --- Concurrency / streaming ---
MAX_CONCURRENT_LLM_CALLS=20
LLM_REQUEST_TIMEOUT_SECONDS=15

# --- Auth: hardcoded API keys (dev). Comma-separated key:tier pairs would also work,
# but we keep them in app/auth.py for clarity. Override per-tier model lists via env if needed. ---

# --- Langfuse (optional in dev; required for phase 10) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
